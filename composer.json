{
  "name": "memran/marwa-error-handler",
  "description": "Framework-agnostic PHP error handling with PSR-3 logging, optional debug reporting, and safe fallback rendering.",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "error-handler",
    "php",
    "psr-3",
    "exception",
    "debug"
  ],
  "autoload": {
    "psr-4": {
      "Marwa\\ErrorHandler\\": "src/"
    }
  },
  "require": {
    "php": ">=8.1",
    "psr/log": "^3.0"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.80",
    "phpstan/phpstan": "^2.1",
    "phpunit/phpunit": "^10.0"
  },
  "prefer-stable": true,
  "config": {
    "sort-packages": true
  },
  "scripts": {
    "test": "phpunit",
    "test:coverage": "phpunit --coverage-text",
    "analyse": "phpstan analyse src --debug --memory-limit=512M",
    "lint": "php-cs-fixer fix --dry-run --diff --sequential",
    "fix": "php-cs-fixer fix --sequential",
    "ci": [
      "@lint",
      "@analyse",
      "@test"
    ]
  }
}
